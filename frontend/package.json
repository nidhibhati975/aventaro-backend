{
  "name": "aventaro-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "android": "node -r ./scripts/node-polyfills.js ./node_modules/react-native/cli.js run-android",
    "clean": "cd android && gradlew.bat clean",
    "rebuild": "npm run clean && npm run run-android",
    "run-android": "adb start-server && adb reverse tcp:8081 tcp:8081 && node -r ./scripts/node-polyfills.js ./node_modules/react-native/cli.js run-android --active-arch-only",
    "android:logcat": "adb logcat *:S AndroidRuntime:E ReactNative:V ReactNativeJS:V",
    "android:install:debug": "cd android && gradlew.bat installDebug -x lint -x test",
    "android:assemble:debug": "cd android && gradlew.bat assembleDebug -x lint -x test",
    "android:release": "node -r ./scripts/node-polyfills.js ./node_modules/react-native/cli.js run-android --mode release",
    "android:assemble:release": "cd android && gradlew.bat assembleRelease",
    "android:bundle:release": "cd android && gradlew.bat bundleRelease",
    "ios": "node -r ./scripts/node-polyfills.js ./node_modules/react-native/cli.js run-ios",
    "start": "node -r ./scripts/node-polyfills.js ./node_modules/react-native/cli.js start",
    "start:android": "adb start-server && adb reverse tcp:8081 tcp:8081 && node -r ./scripts/node-polyfills.js ./node_modules/react-native/cli.js start --host 0.0.0.0 --port 8081 --max-workers 2",
    "start:reset": "node -r ./scripts/node-polyfills.js ./node_modules/react-native/cli.js start --reset-cache",
    "bundle:android": "node -r ./scripts/node-polyfills.js ./node_modules/react-native/cli.js bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle --assets-dest android/app/src/main/res",
    "bundle:ios": "node -r ./scripts/node-polyfills.js ./node_modules/react-native/cli.js bundle --platform ios --dev false --entry-file index.js --bundle-output ios/main.jsbundle --assets-dest ios",
    "lint": "eslint ."
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/netinfo": "^12.0.1",
    "@react-native-documents/picker": "^12.0.1",
    "@react-native-picker/picker": "2.11.1",
    "@react-navigation/bottom-tabs": "^7.5.0",
    "@react-navigation/native": "^7.1.18",
    "@react-navigation/native-stack": "^7.3.29",
    "@sentry/react-native": "^8.2.0",
    "axios": "^1.13.3",
    "date-fns": "^4.1.0",
    "qrcode-react-native": "^0.0.6",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-dotenv": "^3.4.11",
    "react-native-gesture-handler": "^2.28.0",
    "react-native-image-picker": "^8.2.1",
    "react-native-keychain": "^10.0.0",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-nitro-modules": "^0.34.1",
    "react-native-nitro-sound": "^0.2.10",
    "react-native-safe-area-context": "^5.6.0",
    "react-native-screens": "^4.16.0",
    "react-native-vector-icons": "^10.3.0",
    "react-native-video": "^6.19.1",
    "react-native-webview": "13.15.0",
    "socket.io-client": "^4.8.3",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.0.0",
    "@react-native-community/cli-platform-android": "20.0.0",
    "@react-native-community/cli-platform-ios": "20.0.0",
    "@react-native/babel-preset": "0.81.5",
    "@react-native/eslint-config": "0.81.5",
    "@react-native/metro-config": "0.81.5",
    "@react-native/typescript-config": "0.81.5",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.1.0",
    "eslint": "^8.19.0",
    "typescript": "^5.8.3"
  }
}
